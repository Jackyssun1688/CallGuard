<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary_blue"
            app:titleTextColor="@android:color/white"
            app:title="来电卫士 CallGuard" />

        <!-- Scrollable Content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- ===== Status Card ===== -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp"
                    app:contentPadding="16dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🛡️ 防护已开启"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/label_app_description"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:gravity="center"
                            android:layout_marginBottom="16dp" />

                        <Button
                            android:id="@+id/btnToggle"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="开启防护"
                            android:textSize="16sp"
                            android:textColor="@android:color/white"
                            android:backgroundTint="@android:color/holo_green_light" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ===== Settings Card ===== -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="2dp"
                    app:contentPadding="16dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="设置"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <!-- 权限状态 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:id="@+id/textPermissionStatus"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="⚠️ 部分权限缺失"
                                android:textSize="14sp" />

                            <Button
                                android:id="@+id/btnPermissions"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="权限"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- 无障碍 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="无障碍服务（自动接听）"
                                android:textSize="14sp" />

                            <Button
                                android:id="@+id/btnAccessibility"
                                android:layout_width="wrap_content"
                                android:layout_height="40dp"
                                android:text="设置"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- 短信开关 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/pref_send_sms"
                                android:textSize="14sp" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/switchSms"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ===== Call Log Header ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="通话记录"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnClearLogs"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="清空"
                        android:textSize="12sp"
                        style="@style/Widget.Material3.Button.TextButton" />

                    <Button
                        android:id="@+id/btnHelp"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="帮助"
                        android:textSize="12sp"
                        style="@style/Widget.Material3.Button.TextButton" />
                </LinearLayout>

                <!-- ===== Call Log List ===== -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/textEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:text="@string/no_call_logs"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
